# Islamic Preach - Production Environment Variables
# Copy this file to .env.production and fill in the values
# DO NOT commit .env.production to git (add to .gitignore)

# App Configuration
VITE_APP_NAME=Islamic Preach
VITE_APP_URL=https://yourdomain.com

# Google Analytics
VITE_GA_ID=G_XXXXXXXXXX

# Google AdSense
VITE_ADSENSE_CLIENT_ID=ca-pub-xxxxxxxxxxxxxxxx

# API Configuration (optional, for future use)
VITE_API_URL=https://api.yourdomain.com

# Feature Flags
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_ADSENSE=true
VITE_ENABLE_DEBUG=false

# Contact Information
VITE_CONTACT_EMAIL=support@islamicpreach.com
VITE_SUPPORT_EMAIL=support@islamicpreach.com
VITE_BUSINESS_NAME=Islamic Preach
